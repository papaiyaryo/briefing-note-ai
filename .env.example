STRUCTURE_PROVIDER=
OPENAI_OCR_MODEL=
OPENAI_STRUCTURE_MODEL=

# Google Drive / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# App
NEXT_PUBLIC_APP_NAME=briefing-note-ai
